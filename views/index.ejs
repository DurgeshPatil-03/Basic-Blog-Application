<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>BlogSphere</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark">

<div class="container">

<a class="navbar-brand fw-bold" href="/">
BlogSphere
</a>

<a href="/create" class="btn btn-light">
Create Blog
</a>

</div>

</nav>

<div class="container">

<div class="hero">

<h1>Welcome to BlogSphere</h1>

<p>
Share your ideas, knowledge and stories with everyone.
</p>

<a href="/create" class="btn btn-light btn-lg mt-2">
Create Your First Blog
</a>

</div>

<% if(blogs.length===0){ %>

<div class="alert alert-info text-center">

No blogs available.

</div>

<% } %>

<div class="row">

<% blogs.forEach(blog=>{ %>

<div class="col-lg-6 mb-4">

<div class="card blog-card">

<div class="card-body">

<h3 class="card-title">

<%= blog.title %>

</h3>

<p class="author">

👤 <%= blog.author %>

</p>

<p>

<%= blog.content %>

</p>

<p class="date">

📅 <%= blog.createdAt.toDateString() %>

</p>

<hr>

<a
href="/edit/<%= blog._id %>"
class="btn btn-warning">

Edit

</a>

<form
action="/delete/<%= blog._id %>?_method=DELETE"
method="POST"
style="display:inline;">

<button class="btn btn-danger">

Delete

</button>

</form>

</div>

</div>

</div>

<% }) %>

</div>

</div>

<footer>

<p>

© 2026 BlogSphere | Built with Node.js, Express & MongoDB

</p>

</footer>

</body>

</html>